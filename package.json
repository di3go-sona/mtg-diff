{
  "name": "mtg-diff",
  "version": "1.0.0",
  "description": "MTG Decklist Diff Tool",
  "main": "server.js",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --outfile=public/script.js --format=iife --target=es2020 --minify",
    "build:dev": "esbuild src/main.ts --bundle --outfile=public/script.js --format=iife --target=es2020 --sourcemap",
    "typecheck": "tsc --noEmit",
    "start": "node server.js",
    "dev": "npm run build:dev && nodemon server.js --ignore public/",
    "watch": "esbuild src/main.ts --bundle --outfile=public/script.js --format=iife --target=es2020 --sourcemap --watch"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "connect-livereload": "^0.6.1",
    "esbuild": "^0.27.4",
    "livereload": "^0.10.3",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.2"
  }
}
